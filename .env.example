# NextAuth / Google SSO
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
ALLOWED_GOOGLE_DOMAIN="peersyst.org"

# Railway Postgres
DATABASE_URL="postgresql://postgres:password@host:5432/railway"

# Indexer protection
INDEXER_CRON_SECRET="replace-with-random-secret"
# Optional comma-separated allowlist for source IP addresses invoking /api/indexers/run
INDEXER_ALLOWED_IPS=""
# Dashboard URL used by trigger helper script
DASHBOARD_BASE_URL="http://localhost:3000"
# Continuous backend indexer polling interval (milliseconds)
INDEXER_POLL_INTERVAL_MS="30000"

# Auth0 ingestion (optional)
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_CLIENT_ID="your-m2m-client-id"
AUTH0_CLIENT_SECRET="your-m2m-client-secret"
AUTH0_AUDIENCE="https://your-tenant.us.auth0.com/api/v2/"
USER_HASH_SALT="replace-with-private-salt"

# Service metrics ingestion (optional)
RELAYER_BASE_URL="https://your-relayer-host"
CUSTOM_ISSUER_BASE_URL="https://your-custom-issuer-host"
CUSTOM_ISSUER_GO_BASE_URL="https://your-custom-issuer-go-host"

# NEAR indexing (optional)
# Normal RPC for latest-final reads
NEAR_RPC_URL="https://rpc.mainnet.fastnear.com"
# Archival RPC for historical block backfills
NEAR_ARCHIVAL_RPC_URL="https://archival-rpc.mainnet.fastnear.com"
# Comma-separated account IDs to track in near_transactions
NEAR_TRACKED_ACCOUNT_IDS="fast-auth.near"
# Optional initial checkpoint seed when there is no NEAR checkpoint yet
NEAR_BACKFILL_START_HEIGHT="167140093"
# Max historical blocks processed per run (helps stay below provider limits)
NEAR_MAX_BLOCKS_PER_RUN="100"
