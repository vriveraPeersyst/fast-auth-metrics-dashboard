# Railway Postgres
DATABASE_URL="postgresql://postgres:password@host:5432/railway"

# Indexer protection
INDEXER_CRON_SECRET="replace-with-random-secret"
# Optional comma-separated allowlist for source IP addresses invoking /api/indexers/run
INDEXER_ALLOWED_IPS=""
# Dashboard URL used by trigger helper script
DASHBOARD_BASE_URL="http://localhost:3000"
# Continuous backend indexer polling interval (milliseconds)
INDEXER_POLL_INTERVAL_MS="30000"

# Auth0 ingestion (optional)
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_CLIENT_ID="your-m2m-client-id"
AUTH0_CLIENT_SECRET="your-m2m-client-secret"
AUTH0_AUDIENCE="https://your-tenant.us.auth0.com/api/v2/"
USER_HASH_SALT="replace-with-private-salt"
# Optional log-type classification for dashboard account KPIs
AUTH_CREATED_LOG_TYPES="ss,sapi,scu"
AUTH_ACTIVE_SIGN_IN_LOG_TYPES="s,seacft,sepft"
# Connection name matcher used to split Firebase vs Auth0 account metrics
FIREBASE_CONNECTION_MATCH="firebase"

# Service metrics ingestion (optional)
RELAYER_BASE_URL="https://your-relayer-host"
CUSTOM_ISSUER_BASE_URL="https://your-custom-issuer-host"
CUSTOM_ISSUER_GO_BASE_URL="https://your-custom-issuer-go-host"

# NEAR indexing (Railway worker only — not for frontend)
# The RPC pool, request timeout, backfill seed, progress log cadence, block/
# chunk concurrency, max-blocks-per-run, and FastAuth chain-health prober
# knobs are all hardcoded in src/lib/indexers/near-rpc-manager.ts,
# src/lib/indexers/near.ts, and src/lib/indexers/fastauth-head-status.ts.
# Only deployment-specific values below remain env-configurable.

# Comma-separated FastAuth contract IDs used for sign-event derivation (Railway worker)
FASTAUTH_CONTRACT_IDS="fast-auth.near,fast-auth.testnet"
# Optional URL template(s) used to resolve accounts by relayer / user public key.
# Each template supports either a {publicKey} token or a base URL that accepts
# ?publicKey=<key>. Multiple templates can be provided comma-separated via the
# _TEMPLATES variant; the linker will round-robin across them with rate-limit
# aware failover (same strategy as the NEAR RPC pool). If neither is set the
# linker defaults to the FastNEAR public_key lookup.
FASTAUTH_PUBLIC_KEY_ACCOUNTS_URL_TEMPLATES="https://api.fastnear.com/v1/public_key/{publicKey}/all"
# Legacy single-template variable (still honored; merged with _TEMPLATES).
# FASTAUTH_PUBLIC_KEY_ACCOUNTS_URL_TEMPLATE=""
# Optional FastNEAR API key. Not required for public reads; set it once you hit
# the anonymous rate limit during backfill. Sent as `Authorization: Bearer ...`.
# FASTNEAR_API_KEY=""
# Max sign events processed per run by the public-key account linker
FASTAUTH_PUBLIC_KEY_ACCOUNTS_BATCH_SIZE="200"
# Fallback lookback when there is no public-key linker checkpoint yet
FASTAUTH_PUBLIC_KEY_LOOKBACK_DAYS="30"

# Account TVL snapshotting (optional)
# RPC endpoint used by TVL account-state queries (falls back to NEAR_RPC_URL)
TVL_RPC_URL="https://rpc.mainnet.fastnear.com"
# Lookback window (days) to discover sponsored accounts from indexed sign events
TVL_LOOKBACK_DAYS="30"
# Max sponsored accounts snapshot per run
TVL_MAX_ACCOUNTS_PER_RUN="200"
