generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Auth0Log {
  logId       String   @id @map("log_id")
  timestamp   DateTime
  type        String
  description String?
  clientId    String?  @map("client_id")
  clientName  String?  @map("client_name")
  connection  String?
  userIdHash  String?  @map("user_id_hash")
  payload     Json     @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([type, timestamp])
  @@map("auth0_logs")
}

model ServiceMetricSample {
  id          BigInt   @id @default(autoincrement())
  timestamp   DateTime
  serviceName String   @map("service_name")
  metricName  String   @map("metric_name")
  labels      Json     @map("labels_json")
  value       Float
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([serviceName, metricName, timestamp])
  @@map("service_metrics_timeseries")
}

model NearTransaction {
  txHash               String   @id @map("tx_hash")
  blockHeight          BigInt?  @map("block_height")
  blockTimestamp       DateTime? @map("block_timestamp")
  signerAccountId      String?  @map("signer_account_id")
  signerPublicKey      String?  @map("signer_public_key")
  receiverId           String?  @map("receiver_id")
  methodName           String?  @map("method_name")
  executionStatus      String?  @map("execution_status")
  failureReason        String?  @map("failure_reason")
  gasBurnt             BigInt?  @map("gas_burnt")
  attachedDepositYocto String?  @map("attached_deposit_yocto")
  payload              Json     @map("payload_json")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@index([blockHeight])
  @@map("near_transactions")
}

model FastAuthSignEvent {
  id                    BigInt   @id @default(autoincrement())
  txHash                String   @map("tx_hash")
  actionIndex           Int      @map("action_index")
  blockHeight           BigInt   @map("block_height")
  blockTimestamp        DateTime @map("block_timestamp")
  relayerAccountId      String   @map("relayer_account_id")
  relayerPublicKey      String?  @map("relayer_public_key")
  fastAuthContractId    String   @map("fastauth_contract_id")
  guardId               String?  @map("guard_id")
  guardName             String?  @map("guard_name")
  providerType          String   @map("provider_type")
  algorithm             String?  @map("algorithm")
  userSub               String?  @map("user_sub")
  userKeyPath           String?  @map("user_key_path")
  userDomainId          Int?     @map("user_domain_id")
  userDerivedPublicKey  String?  @map("user_derived_public_key")
  projectDappId         String?  @map("project_dapp_id")
  sponsoredAccountId    String?  @map("sponsored_account_id")
  sponsoredAccountHash  String?  @map("sponsored_account_hash")
  verifyPayloadHash     String?  @map("verify_payload_hash")
  signPayloadJson       Json?    @map("sign_payload_json")
  executionStatus       String?  @map("execution_status")
  failureReason         String?  @map("failure_reason")
  gasBurnt              BigInt?  @map("gas_burnt")
  attachedDepositYocto  String?  @map("attached_deposit_yocto")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([txHash, actionIndex])
  @@index([blockTimestamp])
  @@index([relayerAccountId, blockTimestamp])
  @@index([relayerPublicKey, blockTimestamp])
  @@index([userDerivedPublicKey, blockTimestamp])
  @@index([projectDappId, blockTimestamp])
  @@index([providerType, blockTimestamp])
  @@map("fastauth_sign_events")
}

model FastAuthPublicKeyAccount {
  id              BigInt   @id @default(autoincrement())
  publicKey       String   @map("public_key")
  accountId       String   @map("account_id")
  keyPath         String?  @map("key_path")
  predecessorId   String?  @map("predecessor_id")
  domainId        Int?     @map("domain_id")
  firstSeenAt     DateTime @map("first_seen_at")
  lastSeenAt      DateTime @map("last_seen_at")
  lastSourceEventId BigInt? @map("last_source_event_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([publicKey, accountId])
  @@index([accountId])
  @@index([keyPath])
  @@index([lastSeenAt])
  @@index([firstSeenAt])
  @@map("fastauth_public_key_accounts")
}

model Relayer {
  accountId                    String   @id @map("account_id")
  firstSeenAt                  DateTime @map("first_seen_at")
  lastSeenAt                   DateTime @map("last_seen_at")
  totalSignTransactions        Int      @default(0) @map("total_sign_transactions")
  totalGasBurnt                BigInt?  @map("total_gas_burnt")
  totalSponsoredUniqueAccounts Int      @default(0) @map("total_sponsored_unique_accounts")
  projectOwner                 String?  @map("project_owner")
  providerMixJson              Json?    @map("provider_mix_json")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  @@index([lastSeenAt])
  @@map("relayers")
}

model RelayerDapp {
  id                           BigInt   @id @default(autoincrement())
  relayerAccountId             String   @map("relayer_account_id")
  dappContractId               String   @map("dapp_contract_id")
  providerType                 String   @map("provider_type")
  firstSeenAt                  DateTime @map("first_seen_at")
  lastSeenAt                   DateTime @map("last_seen_at")
  totalSignTransactions        Int      @default(0) @map("total_sign_transactions")
  totalGasBurnt                BigInt?  @map("total_gas_burnt")
  totalSponsoredUniqueAccounts Int      @default(0) @map("total_sponsored_unique_accounts")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  @@unique([relayerAccountId, dappContractId, providerType])
  @@index([relayerAccountId, lastSeenAt])
  @@index([dappContractId, lastSeenAt])
  @@map("relayer_dapps")
}

model AccountTvlDailySnapshot {
  id                     BigInt   @id @default(autoincrement())
  accountId              String   @map("account_id")
  snapshotDate           DateTime @map("snapshot_date")
  totalUsd               Float?   @map("total_usd")
  nativeNearBalanceYocto String?  @map("native_near_balance_yocto")
  nativeNearLockedYocto  String?  @map("native_near_locked_yocto")
  assets                 Json     @map("assets_json")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@unique([accountId, snapshotDate])
  @@index([snapshotDate])
  @@map("account_tvl_daily_snapshots")
}

model IndexerCheckpoint {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("indexer_checkpoints")
}

model FastAuthChainHealthSnapshot {
  id                     Int       @id @default(autoincrement())
  computedAt             DateTime  @default(now()) @map("computed_at")
  chainHead              BigInt    @map("chain_head")
  windowStartHeight      BigInt    @map("window_start_height")
  windowEndHeight        BigInt    @map("window_end_height")
  windowBlocks           Int       @map("window_blocks")
  totalTransactions      Int       @map("total_transactions")
  successfulTransactions Int       @map("successful_transactions")
  failedTransactions     Int       @map("failed_transactions")
  distinctRelayers       Int       @map("distinct_relayers")
  lastSuccessTimestamp   DateTime? @map("last_success_timestamp")
  lastSuccessTxHash      String?   @map("last_success_tx_hash")

  @@index([computedAt])
  @@map("fastauth_chain_health_snapshots")
}

model Account {
  accountId          String   @id @map("account_id")
  accountType        String   @map("account_type")
  firstSeenAt        DateTime @map("first_seen_at")
  lastSeenAt         DateTime @map("last_seen_at")
  publicKeyCount     Int      @default(0) @map("public_key_count")
  firstSourceEventId BigInt?  @map("first_source_event_id")
  lastSourceEventId  BigInt?  @map("last_source_event_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([firstSeenAt])
  @@index([lastSeenAt])
  @@index([accountType])
  @@map("accounts")
}
