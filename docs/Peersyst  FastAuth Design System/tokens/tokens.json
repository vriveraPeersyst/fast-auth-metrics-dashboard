{
  "$schema": "https://schemas.peersyst.com/design-tokens/v1",
  "name": "FastAuth",
  "color": {
    "canvas": "#F5F4ED",
    "surface": "#FFFFFF",
    "surfaceMuted": "#EBE9DF",
    "border": "#EBEBEB",
    "borderSubtle": "#D6D4CB",
    "borderRing": "#E1E0DA",
    "ink": "#000000",
    "inkSubtle": "#757571",
    "inkMuted": "#93928E",
    "inkTranslucent": "rgba(0,0,0,0.48)",
    "mint": "#00F29B",
    "mintLight": "#92FFD8",
    "mintSoft": "#9CFFDB",
    "status": {
      "ok": "#1EA874",
      "okBg": "rgba(30,168,116,0.12)",
      "warn": "#B07A08",
      "warnBg": "rgba(176,122,8,0.14)",
      "err": "#C64545",
      "errBg": "rgba(198,69,69,0.12)"
    }
  },
  "radius": { "sm": 8, "md": 12, "lg": 16, "xl": 24, "pill": 100 },
  "shadow": {
    "card": "0 0 8px rgba(0,0,0,0.08)",
    "insetSoft": "inset 0 0 3px rgba(0,0,0,0.08)",
    "insetHeader": "inset 0 0 2px rgba(0,0,0,0.18)"
  },
  "type": {
    "family": {
      "sans": "-apple-system, BlinkMacSystemFont, 'SF Pro Text', 'SF Pro Display', 'Segoe UI', system-ui, sans-serif",
      "mono": "'SF Mono', Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
    },
    "scale": {
      "h1":          { "size": 40, "line": 48, "weight": 700, "track": "-0.01em", "family": "sans" },
      "topbarH1":    { "size": 28, "line": 36, "weight": 700, "track": "-0.01em", "family": "sans" },
      "h2":          { "size": 22, "line": 26, "weight": 700, "track": "-0.01em", "family": "sans" },
      "h3":          { "size": 18, "line": 26, "weight": 700, "track": "-0.01em", "family": "sans" },
      "body":        { "size": 16, "line": 30, "weight": 400, "family": "sans" },
      "bodySmall":   { "size": 14, "line": 24, "weight": 400, "family": "sans" },
      "meta":        { "size": 13, "line": 20, "weight": 400, "family": "sans" },
      "kicker":      { "size": 12, "line": 20, "weight": 500, "track": "0.06em", "uppercase": true, "family": "mono" },
      "metricLabel": { "size": 12, "line": 20, "weight": 500, "track": "0.06em", "uppercase": true, "family": "mono" },
      "metricValue": { "size": 32, "line": 40, "weight": 700, "track": "-0.01em", "family": "sans" },
      "tableHead":   { "size": 11, "line": 16, "weight": 500, "track": "0.06em", "uppercase": true, "family": "mono" },
      "tableCell":   { "size": 13, "line": 20, "weight": 400, "family": "mono" },
      "badge":       { "size": 11, "line": 16, "weight": 700, "track": "0.08em", "uppercase": true, "family": "mono" }
    }
  },
  "motion": {
    "hover": "160ms ease",
    "fast":  "120ms ease",
    "bar":   "220ms ease"
  }
}
